  final Value<String> direction;
  final Value<double> entryPrice;
  final Value<double?> exitPrice;
  final Value<double> stopLoss;
  final Value<double> takeProfit;
  final Value<double> lotSize;
  final Value<DateTime> openedAt;
  final Value<DateTime?> closedAt;
  final Value<double> pnlMoney;
  final Value<double> pnlPips;
  final Value<double> riskRewardActual;
  final Value<String> contractId;
  final Value<String> status;
  final Value<String> regime;
  final Value<String> session;
  final Value<double> confidence;
  final Value<int> rowid;
  const TradesTableCompanion({
    this.id = const Value.absent(),
    this.symbol = const Value.absent(),
    this.direction = const Value.absent(),
    this.entryPrice = const Value.absent(),
    this.exitPrice = const Value.absent(),
    this.stopLoss = const Value.absent(),
    this.takeProfit = const Value.absent(),
    this.lotSize = const Value.absent(),
    this.openedAt = const Value.absent(),
    this.closedAt = const Value.absent(),
    this.pnlMoney = const Value.absent(),
    this.pnlPips = const Value.absent(),
    this.riskRewardActual = const Value.absent(),
    this.contractId = const Value.absent(),
    this.status = const Value.absent(),
    this.regime = const Value.absent(),
    this.session = const Value.absent(),
    this.confidence = const Value.absent(),
    this.rowid = const Value.absent(),
  });
  TradesTableCompanion.insert({
    required String id,
    required String symbol,
    required String direction,
    required double entryPrice,
    this.exitPrice = const Value.absent(),
    required double stopLoss,
    required double takeProfit,
    required double lotSize,
    required DateTime openedAt,
    this.closedAt = const Value.absent(),
    this.pnlMoney = const Value.absent(),
    this.pnlPips = const Value.absent(),
    this.riskRewardActual = const Value.absent(),
    required String contractId,
    required String status,
    required String regime,
    required String session,
    required double confidence,
    this.rowid = const Value.absent(),
  })  : id = Value(id),
        symbol = Value(symbol),
        direction = Value(direction),
        entryPrice = Value(entryPrice),
        stopLoss = Value(stopLoss),
        takeProfit = Value(takeProfit),
        lotSize = Value(lotSize),
        openedAt = Value(openedAt),
