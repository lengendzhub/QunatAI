class TradesTableData extends DataClass implements Insertable<TradesTableData> {
  final String id;
  final String symbol;
  final String direction;
  final double entryPrice;
  final double? exitPrice;
  final double stopLoss;
  final double takeProfit;
  final double lotSize;
  final DateTime openedAt;
  final DateTime? closedAt;
  final double pnlMoney;
  final double pnlPips;
  final double riskRewardActual;
  final String contractId;
  final String status;
  final String regime;
  final String session;
  final double confidence;
  const TradesTableData(
      {required this.id,
      required this.symbol,
      required this.direction,
      required this.entryPrice,
      this.exitPrice,
      required this.stopLoss,
      required this.takeProfit,
      required this.lotSize,
      required this.openedAt,
      this.closedAt,
      required this.pnlMoney,
      required this.pnlPips,
      required this.riskRewardActual,
      required this.contractId,
      required this.status,
      required this.regime,
      required this.session,
      required this.confidence});
  @override
  Map<String, Expression> toColumns(bool nullToAbsent) {
    final map = <String, Expression>{};
    map['id'] = Variable<String>(id);
    map['symbol'] = Variable<String>(symbol);
    map['direction'] = Variable<String>(direction);
    map['entry_price'] = Variable<double>(entryPrice);
    if (!nullToAbsent || exitPrice != null) {
      map['exit_price'] = Variable<double>(exitPrice);
    }
    map['stop_loss'] = Variable<double>(stopLoss);
    map['take_profit'] = Variable<double>(takeProfit);
    map['lot_size'] = Variable<double>(lotSize);
    map['opened_at'] = Variable<DateTime>(openedAt);
    if (!nullToAbsent || closedAt != null) {
      map['closed_at'] = Variable<DateTime>(closedAt);
    }
    map['pnl_money'] = Variable<double>(pnlMoney);
    map['pnl_pips'] = Variable<double>(pnlPips);
    map['risk_reward_actual'] = Variable<double>(riskRewardActual);
    map['contract_id'] = Variable<String>(contractId);
    map['status'] = Variable<String>(status);
    map['regime'] = Variable<String>(regime);
    map['session'] = Variable<String>(session);
    map['confidence'] = Variable<double>(confidence);
    return map;
  }

  TradesTableCompanion toCompanion(bool nullToAbsent) {
    return TradesTableCompanion(
      id: Value(id),
      symbol: Value(symbol),
      direction: Value(direction),
      entryPrice: Value(entryPrice),
      exitPrice: exitPrice == null && nullToAbsent
          ? const Value.absent()
          : Value(exitPrice),
      stopLoss: Value(stopLoss),
      takeProfit: Value(takeProfit),
      lotSize: Value(lotSize),
      openedAt: Value(openedAt),
      closedAt: closedAt == null && nullToAbsent
          ? const Value.absent()
          : Value(closedAt),
      pnlMoney: Value(pnlMoney),
      pnlPips: Value(pnlPips),
      riskRewardActual: Value(riskRewardActual),
      contractId: Value(contractId),
      status: Value(status),
      regime: Value(regime),
      session: Value(session),
      confidence: Value(confidence),
    );
  }

  factory TradesTableData.fromJson(Map<String, dynamic> json,
      {ValueSerializer? serializer}) {
    serializer ??= driftRuntimeOptions.defaultSerializer;
    return TradesTableData(
      id: serializer.fromJson<String>(json['id']),
      symbol: serializer.fromJson<String>(json['symbol']),
      direction: serializer.fromJson<String>(json['direction']),
      entryPrice: serializer.fromJson<double>(json['entryPrice']),
      exitPrice: serializer.fromJson<double?>(json['exitPrice']),
      stopLoss: serializer.fromJson<double>(json['stopLoss']),
      takeProfit: serializer.fromJson<double>(json['takeProfit']),
      lotSize: serializer.fromJson<double>(json['lotSize']),
      openedAt: serializer.fromJson<DateTime>(json['openedAt']),
      closedAt: serializer.fromJson<DateTime?>(json['closedAt']),
      pnlMoney: serializer.fromJson<double>(json['pnlMoney']),
      pnlPips: serializer.fromJson<double>(json['pnlPips']),
      riskRewardActual: serializer.fromJson<double>(json['riskRewardActual']),
      contractId: serializer.fromJson<String>(json['contractId']),
      status: serializer.fromJson<String>(json['status']),
      regime: serializer.fromJson<String>(json['regime']),
      session: serializer.fromJson<String>(json['session']),
      confidence: serializer.fromJson<double>(json['confidence']),
    );
  }
  @override
  Map<String, dynamic> toJson({ValueSerializer? serializer}) {
    serializer ??= driftRuntimeOptions.defaultSerializer;
    return <String, dynamic>{
      'id': serializer.toJson<String>(id),
      'symbol': serializer.toJson<String>(symbol),
      'direction': serializer.toJson<String>(direction),
      'entryPrice': serializer.toJson<double>(entryPrice),
      'exitPrice': serializer.toJson<double?>(exitPrice),
      'stopLoss': serializer.toJson<double>(stopLoss),
      'takeProfit': serializer.toJson<double>(takeProfit),
      'lotSize': serializer.toJson<double>(lotSize),
      'openedAt': serializer.toJson<DateTime>(openedAt),
      'closedAt': serializer.toJson<DateTime?>(closedAt),
      'pnlMoney': serializer.toJson<double>(pnlMoney),
      'pnlPips': serializer.toJson<double>(pnlPips),
      'riskRewardActual': serializer.toJson<double>(riskRewardActual),
      'contractId': serializer.toJson<String>(contractId),
      'status': serializer.toJson<String>(status),
      'regime': serializer.toJson<String>(regime),
      'session': serializer.toJson<String>(session),
      'confidence': serializer.toJson<double>(confidence),
    };
  }

  TradesTableData copyWith(
          {String? id,
          String? symbol,
          String? direction,
          double? entryPrice,
          Value<double?> exitPrice = const Value.absent(),
          double? stopLoss,
          double? takeProfit,
          double? lotSize,
          DateTime? openedAt,
          Value<DateTime?> closedAt = const Value.absent(),
          double? pnlMoney,
          double? pnlPips,
          double? riskRewardActual,
          String? contractId,
          String? status,
          String? regime,
          String? session,
          double? confidence}) =>
      TradesTableData(
        id: id ?? this.id,
        symbol: symbol ?? this.symbol,
        direction: direction ?? this.direction,
        entryPrice: entryPrice ?? this.entryPrice,
        exitPrice: exitPrice.present ? exitPrice.value : this.exitPrice,
        stopLoss: stopLoss ?? this.stopLoss,
        takeProfit: takeProfit ?? this.takeProfit,
        lotSize: lotSize ?? this.lotSize,
        openedAt: openedAt ?? this.openedAt,
        closedAt: closedAt.present ? closedAt.value : this.closedAt,
        pnlMoney: pnlMoney ?? this.pnlMoney,
        pnlPips: pnlPips ?? this.pnlPips,
        riskRewardActual: riskRewardActual ?? this.riskRewardActual,
        contractId: contractId ?? this.contractId,
        status: status ?? this.status,
        regime: regime ?? this.regime,
        session: session ?? this.session,
        confidence: confidence ?? this.confidence,
      );
  TradesTableData copyWithCompanion(TradesTableCompanion data) {
    return TradesTableData(
      id: data.id.present ? data.id.value : this.id,
      symbol: data.symbol.present ? data.symbol.value : this.symbol,
      direction: data.direction.present ? data.direction.value : this.direction,
      entryPrice:
          data.entryPrice.present ? data.entryPrice.value : this.entryPrice,
      exitPrice: data.exitPrice.present ? data.exitPrice.value : this.exitPrice,
      stopLoss: data.stopLoss.present ? data.stopLoss.value : this.stopLoss,
      takeProfit:
          data.takeProfit.present ? data.takeProfit.value : this.takeProfit,
      lotSize: data.lotSize.present ? data.lotSize.value : this.lotSize,
      openedAt: data.openedAt.present ? data.openedAt.value : this.openedAt,
      closedAt: data.closedAt.present ? data.closedAt.value : this.closedAt,
      pnlMoney: data.pnlMoney.present ? data.pnlMoney.value : this.pnlMoney,
      pnlPips: data.pnlPips.present ? data.pnlPips.value : this.pnlPips,
      riskRewardActual: data.riskRewardActual.present
          ? data.riskRewardActual.value
          : this.riskRewardActual,
      contractId:
          data.contractId.present ? data.contractId.value : this.contractId,
      status: data.status.present ? data.status.value : this.status,
      regime: data.regime.present ? data.regime.value : this.regime,
      session: data.session.present ? data.session.value : this.session,
      confidence:
          data.confidence.present ? data.confidence.value : this.confidence,
    );
  }

  @override
  String toString() {
    return (StringBuffer('TradesTableData(')
          ..write('id: $id, ')
          ..write('symbol: $symbol, ')
          ..write('direction: $direction, ')
          ..write('entryPrice: $entryPrice, ')
          ..write('exitPrice: $exitPrice, ')
          ..write('stopLoss: $stopLoss, ')
          ..write('takeProfit: $takeProfit, ')
          ..write('lotSize: $lotSize, ')
          ..write('openedAt: $openedAt, ')
          ..write('closedAt: $closedAt, ')
          ..write('pnlMoney: $pnlMoney, ')
          ..write('pnlPips: $pnlPips, ')
          ..write('riskRewardActual: $riskRewardActual, ')
          ..write('contractId: $contractId, ')
          ..write('status: $status, ')
          ..write('regime: $regime, ')
          ..write('session: $session, ')
          ..write('confidence: $confidence')
          ..write(')'))
        .toString();
  }

  @override
  int get hashCode => Object.hash(
      id,
      symbol,
      direction,
      entryPrice,
      exitPrice,
      stopLoss,
      takeProfit,
      lotSize,
      openedAt,
      closedAt,
      pnlMoney,
      pnlPips,
      riskRewardActual,
      contractId,
      status,
      regime,
      session,
      confidence);
  @override
  bool operator ==(Object other) =>
      identical(this, other) ||
      (other is TradesTableData &&
          other.id == this.id &&
          other.symbol == this.symbol &&
          other.direction == this.direction &&
          other.entryPrice == this.entryPrice &&
          other.exitPrice == this.exitPrice &&
          other.stopLoss == this.stopLoss &&
          other.takeProfit == this.takeProfit &&
          other.lotSize == this.lotSize &&
          other.openedAt == this.openedAt &&
          other.closedAt == this.closedAt &&
          other.pnlMoney == this.pnlMoney &&
          other.pnlPips == this.pnlPips &&
          other.riskRewardActual == this.riskRewardActual &&
          other.contractId == this.contractId &&
          other.status == this.status &&
          other.regime == this.regime &&
          other.session == this.session &&
