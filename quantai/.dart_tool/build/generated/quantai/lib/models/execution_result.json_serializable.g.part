_$ExecutionResultImpl _$$ExecutionResultImplFromJson(
        Map<String, dynamic> json) =>
    _$ExecutionResultImpl(
      contractId: json['contractId'] as String,
      symbol: json['symbol'] as String,
      direction: json['direction'] as String,
      filledPrice: (json['filledPrice'] as num).toDouble(),
      stopLoss: (json['stopLoss'] as num).toDouble(),
      takeProfit: (json['takeProfit'] as num).toDouble(),
      lotSize: (json['lotSize'] as num).toDouble(),
      executedAt: DateTime.parse(json['executedAt'] as String),
      raw: json['raw'] as Map<String, dynamic>,
    );

Map<String, dynamic> _$$ExecutionResultImplToJson(
        _$ExecutionResultImpl instance) =>
    <String, dynamic>{
      'contractId': instance.contractId,
      'symbol': instance.symbol,
      'direction': instance.direction,
      'filledPrice': instance.filledPrice,
      'stopLoss': instance.stopLoss,
      'takeProfit': instance.takeProfit,
      'lotSize': instance.lotSize,
      'executedAt': instance.executedAt.toIso8601String(),
      'raw': instance.raw,
    };
